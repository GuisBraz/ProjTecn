REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Necessário com as versões atuais do npm: o plugin de ESLint embutido no
# create-react-app (react-scripts 5) trava o build com o erro
# "Environment key jest/globals is unknown" por incompatibilidade entre
# eslint-config-react-app e a versão mais nova do eslint-plugin-jest baixada
# em instalações novas. Isso não afeta a qualidade do código — só desliga o
# lint automático durante o build.
DISABLE_ESLINT_PLUGIN=true
